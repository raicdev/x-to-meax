# X username without @. Used to build the Nitter RSS or HTML URL.
X_USERNAME=

# Source to read from Nitter. rss is stable; html can detect page updates sooner.
# Use api to read from this project's self-hosted tweets API instead of Nitter.
NITTER_SOURCE=rss

# Optional: use a specific RSS URL instead of building one from X_USERNAME.
# Useful when switching to another Nitter instance.
NITTER_RSS_URL=

# Optional: use a specific Nitter profile HTML URL when NITTER_SOURCE=html.
NITTER_HTML_URL=

# Self-hosted tweets API source used when NITTER_SOURCE=api.
TWEETS_API_BASE_URL=http://127.0.0.1:3000
TWEETS_API_URL=
TWEETS_API_LIMIT=100

# Optional: base URL used with X_USERNAME. (nt.vern.cc is better source than nitter.net)
NITTER_BASE_URL=https://nt.vern.cc

# User-Agent sent to RSS servers.
RSS_USER_AGENT=x-to-meax/0.1.0

# Optional JSON object for extra RSS request headers.
RSS_REQUEST_HEADERS_JSON=

# Meax Bearer token.
MEAX_BEARER_TOKEN=

# Usually you do not need to change this.
MEAX_POSTS_URL=https://api.meax.jp/api/posts

# Poll interval in seconds.
POLL_INTERVAL_SECONDS=300

# Forward replies. Replies are skipped by default.
FORWARD_REPLIES=false

# Attach images from the self-host tweets API when forwarding to Meax.
FORWARD_IMAGES=true
MAX_MEDIA_ATTACHMENTS=4

# Append the source X post URL to forwarded Meax posts.
INCLUDE_X_POST_URL=false

# On first run, forward the fetched posts instead of only recording them as already seen.
BACKFILL_ON_START=false

# Fetch and detect posts without posting to Meax or updating state.
DRY_RUN=false

# Where processed post keys are persisted.
STATE_FILE=data/state.json

# Self-hosted tweets API.
API_HOST=0.0.0.0
API_PORT=3000
API_DEFAULT_LIMIT=20
API_MAX_LIMIT=100
API_FETCH_TIMEOUT_MS=15000
API_CORS_ORIGIN=*

# X session cookie values used by the direct X GraphQL backend.
# Read them from your own logged-in x.com browser session.
X_AUTH_TOKEN=
X_CT0=

# Optional: override the web bearer token or browser User-Agent if X changes them.
X_BEARER_TOKEN=
X_USER_AGENT=

# Optional: "auto" generates the header using the same pair-dictionary approach as Nitter.
# Set a fixed value only for debugging.
X_CLIENT_TRANSACTION_ID=auto
