# X username without @. Used to build the Nitter RSS or HTML URL.
X_USERNAME=

# Source to read from Nitter. rss is stable; html can detect page updates sooner.
NITTER_SOURCE=rss

# Optional: use a specific RSS URL instead of building one from X_USERNAME.
# Useful when switching to another Nitter instance.
NITTER_RSS_URL=

# Optional: use a specific Nitter profile HTML URL when NITTER_SOURCE=html.
NITTER_HTML_URL=

# Optional: base URL used with X_USERNAME.
NITTER_BASE_URL=https://nitter.net

# User-Agent sent to RSS servers.
RSS_USER_AGENT=x-to-meax/0.1.0

# Optional JSON object for extra RSS request headers.
RSS_REQUEST_HEADERS_JSON=

# Meax Bearer token.
MEAX_BEARER_TOKEN=

# Usually you do not need to change this.
MEAX_POSTS_URL=https://api.meax.jp/api/posts

# Poll interval in seconds.
POLL_INTERVAL_SECONDS=300

# Forward replies. Replies are skipped by default.
FORWARD_REPLIES=false

# Append an X post link to normal forwarded posts.
INCLUDE_POST_LINK=false

# On first run, forward the fetched RSS items instead of only recording them as already seen.
BACKFILL_ON_START=false

# Where processed RSS item keys are persisted.
STATE_FILE=data/state.json
